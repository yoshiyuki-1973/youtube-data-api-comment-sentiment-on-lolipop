    // 使用するモデル（gemini-2.5-flash / gemini-2.5-pro）
    'GEMINI_MODEL'    => 'gemini-2.5-flash',

    // ===== MySQL（ロリポップ マイSQL） =====
    // ロリポップ管理画面の「データベース」から確認する
    'DB_HOST'    => 'mysql**.lolipop.jp',  // ロリポップ管理画面で確認
    'DB_NAME'    => 'your_database_name',  // データベース名
    'DB_USER'    => 'your_db_user',        // ユーザー名
    'DB_PASS'    => 'your_db_password',    // パスワード
    'DB_CHARSET' => 'utf8mb4',
